{
  "name": "typescript-stakeholder",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "format": "prettier --check src test package.json tsconfig.json",
    "format:write": "prettier --write src test package.json tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/runtime.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
